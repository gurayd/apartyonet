rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasProfile() {
      return signedIn() && myProfile().data != null;
    }

    function isActive() {
      return hasProfile() && myProfile().data.status == "active";
    }

    function myRole() {
      return hasProfile() ? myProfile().data.role : "";
    }

    function mySiteId() {
      return hasProfile() ? myProfile().data.siteId : "";
    }

    function isSuperAdmin() {
      return isActive() && myRole() == "super_admin";
    }

    function isSiteManager() {
      return isActive() && myRole() == "site_manager";
    }

    function isAdmin() {
      return isActive() && myRole() == "admin";
    }

    function isAssistantManager() {
      return isActive() && myRole() == "assistant_manager";
    }

    function isResident() {
      return isActive() && myRole() == "resident";
    }

    function isManager() {
      return isSuperAdmin() || isAdmin() || isSiteManager() || isAssistantManager();
    }

    function sameSite(resourceData) {
      return isSuperAdmin() || resourceData.siteId == mySiteId();
    }

    function isBootstrapAdminEmail() {
      return signedIn() && request.auth.token.email == "guraydinsel@gmail.com";
    }

    function isOwnUserDoc(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function sameSiteStrict(resourceData) {
      return resourceData.siteId == mySiteId();
    }

    function validRole(role) {
      return role in ["super_admin", "admin", "site_manager", "assistant_manager", "resident"];
    }

    function validStatus(status) {
      return status in ["active", "inactive"];
    }

    match /users/{uid} {
      allow read: if signedIn() && (
        request.auth.uid == uid ||
        ((isSuperAdmin() || isAdmin()) && sameSite(resource.data))
      );

      allow create: if (
          isSuperAdmin()
          && validRole(request.resource.data.role)
          && validStatus(request.resource.data.status)
        ) || (
          isAdmin()
          && sameSiteStrict(request.resource.data)
          && request.resource.data.role in ["site_manager", "assistant_manager", "resident"]
          && validStatus(request.resource.data.status)
        ) || (
          isOwnUserDoc(uid)
          && !hasProfile()
          && isBootstrapAdminEmail()
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.role == "super_admin"
          && request.resource.data.siteId == "*"
          && validStatus(request.resource.data.status)
        );

      allow update: if (
          isSuperAdmin()
          && validRole(request.resource.data.role)
          && validStatus(request.resource.data.status)
        ) || (
          isAdmin()
          && sameSiteStrict(resource.data)
          && sameSiteStrict(request.resource.data)
          && request.resource.data.role in ["site_manager", "assistant_manager", "resident"]
          && validStatus(request.resource.data.status)
        ) || (
          isOwnUserDoc(uid)
          && isBootstrapAdminEmail()
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.role == "super_admin"
          && request.resource.data.siteId == "*"
          && validStatus(request.resource.data.status)
        );

      allow delete: if isSuperAdmin()
        || (
          isAdmin()
          && sameSiteStrict(resource.data)
          && !(resource.data.role in ["super_admin", "admin"])
        );
    }

    match /sites/{siteId} {
      allow read: if isActive() && (isSuperAdmin() || siteId == mySiteId());
      allow create, update: if isSuperAdmin() || (isAdmin() && siteId == mySiteId());
      allow delete: if isSuperAdmin();
    }

    match /basvurular/{docId} {
      allow create: if true;
      allow read: if isActive() && sameSite(resource.data);
      allow update: if (isSuperAdmin() && sameSite(resource.data) && sameSite(request.resource.data))
        || (isAdmin() && sameSiteStrict(resource.data) && sameSiteStrict(request.resource.data));
      allow delete: if (isSuperAdmin() && sameSite(resource.data))
        || (isAdmin() && sameSiteStrict(resource.data));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
